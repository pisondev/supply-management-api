    {
      "name": "POST Create Warehouse",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now();",
              "pm.environment.set('warehouse_name', `QA Warehouse ${suffix}`);",
              "pm.environment.set('warehouse_location', `QA Location ${suffix}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json && json.data && json.data.id) {",
              "  pm.environment.set('warehouse_id', json.data.id);",
              "}",
              "",
              "pm.test('Warehouse ID tersimpan', function () {",
              "  pm.expect(pm.environment.get('warehouse_id')).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{warehouse_name}}\",\n  \"location\": \"{{warehouse_location}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{api_v1}}/warehouses",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "warehouses"
          ]
        },
        "description": "Membuat warehouse baru untuk kebutuhan QA flow."
      },
      "response": []
    },
