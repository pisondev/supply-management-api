  "item": [
    {
      "name": "GET Seed Warehouse Stocks",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Stocks response memiliki items', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data).to.exist;",
              "  pm.expect(json.data.items).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{api_v1}}/inventory/stocks?page={{inventory_page}}&limit={{inventory_limit}}&warehouse_id={{inventory_seed_warehouse_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "inventory",
            "stocks"
          ],
          "query": [
            {
              "key": "page",
              "value": "{{inventory_page}}"
            },
            {
              "key": "limit",
              "value": "{{inventory_limit}}"
            },
            {
              "key": "warehouse_id",
              "value": "{{inventory_seed_warehouse_id}}"
            }
          ]
        },
        "description": "Mengambil daftar stok untuk warehouse seed ID 1 sebagai baseline sebelum movement baru dibuat."
      },
      "response": []
    },
    {
      "name": "POST Record Movement IN",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('inventory_reference_in', `QA-IN-${Date.now()}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Movement IN tercatat', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.movement_type).to.eql('IN');",
              "  pm.expect(json.data.reference_code).to.eql(pm.environment.get('inventory_reference_in'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"warehouse_id\": {{inventory_seed_warehouse_id}},\n  \"ingredient_id\": \"{{inventory_seed_ingredient_id}}\",\n  \"supplier_id\": \"{{inventory_seed_supplier_id}}\",\n  \"movement_type\": \"IN\",\n  \"quantity\": {{inventory_in_quantity}},\n  \"reference_code\": \"{{inventory_reference_in}}\",\n  \"notes\": \"QA stock in using seeded supplier and ingredient\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{api_v1}}/inventory/movements",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "inventory",
            "movements"
          ]
        },
        "description": "Mencatat stock IN untuk item seed. Endpoint ini mensyaratkan supplier_id ada saat movement_type = IN."
      },
      "response": []
    },
